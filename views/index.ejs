<%- include('partials/header') %>


<h1>Home</h1>


<% if (user) {%>
<% folders.map((folder) => {%>
<div class="folderContainer">
    <%= folder.name %>
  <div class="filesContainer">
    <% folder.files.map((file) => {%>

    <div class="fileContainer">

      <form action="/file/edit/<%= file.id %>" method="POST">
        <input type="text" name="name" id="name">
        <button>submit</button>


      </form>


      <!-- <a class="fileName" href="/file/info/<%= file.id %>"><%= file.name %></a> -->



      <div class="btnContainer">
        <form action="/file/delete/<%= file.id %>" method="POST">
          <button class="btn">✕</button>
        </form>
        <a class="btn" href="/file/download/<%= file.id %>">↓</a>
        <a class="btn" href="/file/edit/<%= file.id %>">✎</a>

      </div>
    </div>
    <%}) %>
  </div>




</div>

<%}) %>



<%} %>


<%- include('partials/footer') %>